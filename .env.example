# Copy to .env and fill in:

# Required if you plan to re-run TMDB enrichment (src/data_enrichment.py).
# Get one at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Defaults are project-relative; override if you mount models elsewhere
# (e.g. when running in Docker with read-only model volumes).
MODELS_DIR=./models
ML_DATA_DIR=./ml-32m
CACHE_DIR=./.api_cache
# Content features base path (without extension; loader reads .npz + .json).
# - content_genome:  Tag Genome 2021 (1,084 curated tags, 9,734 films)
# - content_features: user-tag TF-IDF (20k vocab, all 87k films, noisier)
CONTENT_FEATURES=./data/content_genome

# Which model files to load at startup. Defaults to the full-catalog
# ml-32m models trained via scripts/train_svd.py and scripts/train_als.py.
# Default to the slim 145MB pickle (trainset ratings dicts dropped — fits
# in Docker Desktop's default memory limit). Use svd_full.pkl (1GB) if you
# have headroom and want the full trainset attached.
SVD_FILE=svd_full_slim.pkl
ALS_FILE=als_full.pkl
