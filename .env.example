# Copy to .env and fill in:

# Optional. Server-side TMDB key. Raw Letterboxd CSV uploads (no tmdb_id
# column) map via local title+year matching against the catalog, so a key is
# NOT required for uploads to work. When set, it adds a TMDB-search fallback
# for titles not found locally (and powers scripts/add_tmdb_ids.py).
# Get one at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Defaults are project-relative; override if you mount models elsewhere
# (e.g. when running in Docker with read-only model volumes).
MODELS_DIR=./models
ML_DATA_DIR=./ml-32m
CACHE_DIR=./.api_cache
# Content features base path (without extension; loader reads .npz + .json).
# - content_genome:  Tag Genome 2021 (1,084 curated tags, 9,734 films)
# - content_features: user-tag TF-IDF (20k vocab, all 87k films, noisier)
CONTENT_FEATURES=./data/content_genome

# Which model files to load at startup. Defaults to the full-catalog
# ml-32m models trained via scripts/train_svd.py and scripts/train_als.py.
# Default to the slim 145MB pickle (trainset ratings dicts dropped — fits
# in Docker Desktop's default memory limit). Use svd_full.pkl (1GB) if you
# have headroom and want the full trainset attached.
SVD_FILE=svd_full_slim.pkl
ALS_FILE=als_full.pkl

# Optional extra content scorers, comma-separated base paths (without .npz).
# Director features are a known cinephile signal; on by default if built.
# CONTENT_FEATURES_EXTRA=/app/data/content_directors,/app/data/content_overviews

# Per-scorer weights, comma-separated. First is the primary (content_genome),
# then each entry in CONTENT_FEATURES_EXTRA. Genome carries the strongest
# clean signal; directors at ~0.4 nudges without diluting.
# CONTENT_FEATURES_WEIGHTS=1.0,0.4

# --- Public-deployment hardening (optional; sane defaults shown) ---
# Comma-separated allowed CORS origins. MUST include your real frontend
# origin in production, e.g. https://movienight.alex-wf.com
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:4173
# Precomputed popularity table (build with scripts/build_popularity.py) so the
# API skips loading the full ~32M-row ratings.csv at startup.
POPULARITY_FILE=./data/popularity.json
# Max upload body (bytes) and max TMDB-enrichment rows per request (DoS guards).
MAX_UPLOAD_BYTES=10485760
MAX_ENRICH_ROWS=5000
# Per-IP fixed-window rate limits.
RATE_WINDOW_SECONDS=60
RATE_LIMIT_PER_MIN=60
RATE_LIMIT_HEAVY_PER_MIN=12
